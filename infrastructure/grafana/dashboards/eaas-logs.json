{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "transparent": false,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count_over_time({app=~\"$app\"}[5m])) by (app)",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "transparent": false,
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{app=~\"$app\"} |= \"Error\" or {app=~\"$app\"} |= \"Exception\"",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Logs by Correlation ID",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "transparent": false,
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{app=~\"$app\"} | json | CorrelationId=`$correlationId`",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Slow Requests (>1s)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "transparent": false,
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{app=\"eaas-api\"} | json | Elapsed > 1000",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["eaas", "logs"],
  "templating": {
    "list": [
      {
        "name": "correlationId",
        "label": "Correlation ID",
        "type": "textbox",
        "current": { "value": "" },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "app",
        "label": "App",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(app)",
        "regex": "eaas-.*",
        "multi": true,
        "includeAll": true,
        "current": { "value": ["$__all"], "text": ["All"] },
        "hide": 0,
        "skipUrlSync": false,
        "refresh": 2
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EaaS - Log Analysis",
  "uid": "eaas-logs",
  "version": 1
}
