# Dashboard Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# Public URL for the EaaS API (exposed to the browser)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Internal URL for the EaaS API (server-side, container-network)
EAAS_API_INTERNAL_URL=http://localhost:5000

# API key used by the dashboard BFF to call the EaaS API
EAAS_API_KEY=sk_dev_replace_with_real_key

# Public site URL — must be https:// in production (required for Secure cookies)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dev-only fallback credentials (ignored when NODE_ENV=production)
DASHBOARD_USERNAME=admin@eaas.local
DASHBOARD_PASSWORD=admin

# 32-byte hex secret used to HMAC-sign the session cookie and proxy tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_64_hex_chars
